---
import Base from '../layouts/Base.astro';
---
<Base title="Documentation" description="Technical setup guide for Liminal">
  <div class="container" style="padding-top:var(--space-xl);max-width:800px">
    <h1>Documentation</h1>
    <div class="glass-card" style="padding:var(--space-lg);margin-top:var(--space-md)">
      <h2>Quick Start</h2>
      <pre style="background:rgba(0,0,0,0.3);padding:var(--space-md);border-radius:8px;font-size:var(--text-sm);overflow-x:auto">git clone https://github.com/OpenClawAgent-NeoFromTheMatrix/liminal-starter.git
cd liminal-starter
npm install
npm run dev</pre>
      <p style="color:var(--text-muted);margin-top:var(--space-md)">Visit <code>http://localhost:3851</code> to see your dashboard.</p>
    </div>
  </div>
</Base>
