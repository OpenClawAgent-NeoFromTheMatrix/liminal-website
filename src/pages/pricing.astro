---
import Base from '../layouts/Base.astro';
---
<Base title="Pricing" description="Start free, scale as you grow">
  <div class="container" style="padding-top:var(--space-xl)">
    <h1 style="text-align:center;margin-bottom:var(--space-lg)">Pricing</h1>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:var(--space-lg);max-width:900px;margin:0 auto">
      <div class="glass-card" style="padding:var(--space-lg)">
        <h3 style="color:var(--text-muted)">Free</h3>
        <div style="font-size:2rem;font-weight:700;margin:var(--space-sm) 0">$0</div>
        <ul style="list-style:none;padding:0;font-size:var(--text-sm);color:var(--text-secondary)">
          <li>Architecture overview</li><li>First 3 guides</li><li>Community Discord</li>
        </ul>
      </div>
      <div class="glass-card" style="padding:var(--space-lg);border:1px solid var(--accent-cyan)">
        <h3 style="color:var(--accent-cyan)">Pro</h3>
        <div style="font-size:2rem;font-weight:700;margin:var(--space-sm) 0">$49</div>
        <ul style="list-style:none;padding:0;font-size:var(--text-sm);color:var(--text-secondary)">
          <li>Complete playbook</li><li>SOUL templates</li><li>Batch prompts</li><li>Email support</li>
        </ul>
      </div>
      <div class="glass-card" style="padding:var(--space-lg)">
        <h3 style="color:var(--accent-purple)">Enterprise</h3>
        <div style="font-size:2rem;font-weight:700;margin:var(--space-sm) 0">$999</div>
        <ul style="list-style:none;padding:0;font-size:var(--text-sm);color:var(--text-secondary)">
          <li>Custom agent design</li><li>1:1 coaching</li><li>Private Discord</li><li>Implementation support</li>
        </ul>
      </div>
    </div>
  </div>
</Base>
